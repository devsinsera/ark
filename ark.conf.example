# ── Ark config — the one place to edit what gets baked into images ──
#
# SUPER SIMPLE: copy this to ~/.ark/ark.conf and edit. The bake scripts source
# it automatically. Everything is optional — anything you leave blank falls back
# to a sensible default (or to ~/.ark/wifi.env for WiFi, ~/.ssh/id_ed25519.pub
# for the SSH key). Then build with:   ./ark bake <profile>
#
#   mkdir -p ~/.ark && cp ark.conf.example ~/.ark/ark.conf && nano ~/.ark/ark.conf

# ── Operator identity (applies to every image) ─────────────────────
SSH_PUBKEY_FILE="$HOME/.ssh/id_ed25519.pub"   # baked for peta + root login
WIFI_SSID=""                                   # blank → read from ~/.ark/wifi.env
WIFI_KEY=""                                    # blank → read from ~/.ark/wifi.env
WIFI_COUNTRY="AU"                              # WLAN regulatory domain — REQUIRED for Pi Zero 2 W
                                               #   (radio is rfkill-blocked until this is set)
TIMEZONE="Australia/Brisbane"
LOCALE="en_AU.UTF-8"

# ── WireGuard "wiretunnel" (optional, any image) ───────────────────
# Point at an EXISTING WireGuard .conf and Ark bakes it to /etc/wireguard/wg0.conf
# and enables wg-quick@wg0 on boot (installs wireguard-tools). Leave blank = off.
WG_CONF=""                                     # e.g. ~/.ark/wireguard/wg0.conf

# ── Standard hardening baked into every kiosk image (leave =1) ─────
MASK_FIRSTBOOT_WIZARD=1   # mask userconfig.service — kills the "which username…" box
WIFI_RFKILL_UNBLOCK=1     # boot service: set WiFi country + rfkill unblock (Zero 2 W)

# ── Per-profile: mirrorloop-kiosk ──────────────────────────────────
MIRRORLOOP_HOSTNAME="mirrorloop-kiosk"
MIRRORLOOP_SUPABASE_URL="https://lkhtgkmivqwgnvzmjbhr.supabase.co"
MIRRORLOOP_SUPABASE_ANON_KEY=""   # blank → read from "Sinsera Core/.env.production"
MIRRORLOOP_EMAIL="peta.stockdale@outlook.com"
MIRRORLOOP_PASSWORD=""            # blank by design — set on the Pi after first boot
MIRRORLOOP_UNIT_SLUG="test-zero2w"
MIRRORLOOP_UNIT_LABEL="TEST ZERO 2 W"
MIRRORLOOP_WAVESHARE_BL_OFF=1     # turn the Waveshare 1.44in HAT backlight off (uses HDMI TV)

# ── Per-profile: sinsera-kiosk ─────────────────────────────────────
SINSERA_HOSTNAME="sinsera-kiosk"
SINSERA_KIOSK_URL="https://sinsera.co/"
