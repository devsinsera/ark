# /public_html/ark/.htaccess
#
# Override the parent /public_html/.htaccess SPA fallback so paths
# under /ark/* resolve back to /ark/index.html instead of bouncing
# up to Sinsera Core's root.

Options -MultiViews
RewriteEngine On
RewriteBase /ark/

# Don't rewrite the entry document.
RewriteRule ^index\.html$ - [L]

# SPA fallback within /ark/.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /ark/index.html [L]

<IfModule mod_headers.c>
  <FilesMatch "\.(?:css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(?:woff2?|ttf|eot)$">
    Header set Cache-Control "public, max-age=86400, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(?:svg|jpg|jpeg|png|gif|webp|ico)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>
