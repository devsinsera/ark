# Build + deps
app/node_modules
app/dist
app/dist.zip
app/.vite

# Local secrets
app/.env.local
app/.env.production

# OS image binaries — too big for git (~1 GB raw, ~200 MB compressed).
# Keep these locally; they're seed flash images, not source code.
Os/*.img
Os/*.img.xz
Os/*.iso
Os/*.zip

# macOS metadata
.DS_Store
*.log

# Installer engine working dirs — staged source + plan artefacts +
# backup tarballs. These can contain dual-use security tooling (e.g.
# network/recon code) that AV products like Norton will quarantine.
# Keep them local; the engine re-creates them deterministically from
# a profile.json + source URL. We ALWAYS keep builds/<profile>/profile.json
# (the build profile itself); only the engine's outputs are ignored.
builds/*/src/
builds/*/scripts/
builds/*/config/
builds/*/exports/
builds/*/install.log
builds/*/install.plan.json
builds/*/install.plan.sh
builds/*/manifest.json

# Locally-relocated RaspyJack source tree (moved out of builds/ to
# dodge AV quarantine). Same reason as above — keep local.
Jack/
cant-phish-here/
