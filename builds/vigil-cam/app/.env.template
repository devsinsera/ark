# Vigil — security camera config. Baked by vigil-cam-bake.sh.
# VIGIL_PASSWORD ships BLANK by design: the LAN MJPEG runs immediately, but the
# PRIVATE cloud feed (sinsera.co/vigil) stays OFF until you set it over SSH:
#   ssh peta@vigil-cam.local 'sudo sed -i "s/^VIGIL_PASSWORD=.*/VIGIL_PASSWORD=yourpass/" /opt/vigil/.env && sudo systemctl restart vigil'
SUPABASE_URL=
SUPABASE_ANON_KEY=
VIGIL_EMAIL=
VIGIL_PASSWORD=
CAMERA_SLUG=front-door
CAMERA_LABEL=FRONT DOOR

# ── Tuning (Zero 2 W defaults) ──
CAM_WIDTH=640
CAM_HEIGHT=480
CAM_FPS=15
CAM_INDEX=0
JPEG_QUALITY=75
CLOUD_FPS=2
CLOUD_FPS_MOTION=4
MJPEG_PORT=8090
# MJPEG_TOKEN=        # optional shared secret → /stream/<token>
MOTION_THRESHOLD=5.0
MOTION_MIN_AREA=0.012
MOTION_COOLDOWN_S=8
HEARTBEAT_S=30
