# Vigil — security camera config. Baked by vigil-cam-bake.sh.
# VIGIL_PASSWORD ships BLANK by design: the LAN MJPEG runs immediately, but the
# PRIVATE cloud feed (sinsera.co/vigil) stays OFF until you set it over SSH:
#   ssh peta@vigil-cam.local 'sudo sed -i "s/^VIGIL_PASSWORD=.*/VIGIL_PASSWORD=yourpass/" /opt/vigil/.env && sudo systemctl restart vigil'
SUPABASE_URL=
SUPABASE_ANON_KEY=
VIGIL_EMAIL=
VIGIL_PASSWORD=
CAMERA_SLUG=front-door
CAMERA_LABEL=FRONT DOOR

# ── Tuning (Zero 2 W defaults) ──
CAM_WIDTH=640
CAM_HEIGHT=480
CAM_FPS=15
CAM_INDEX=0
JPEG_QUALITY=75
CLOUD_FPS=2
CLOUD_FPS_MOTION=4
MJPEG_PORT=8090
# MJPEG_TOKEN=        # optional shared secret → /stream/<token>
MOTION_THRESHOLD=5.0
MOTION_MIN_AREA=0.012
MOTION_COOLDOWN_S=8
HEARTBEAT_S=30

# ── Object detection (MobileNet-SSD via OpenCV DNN) ──
# DETECT=1                 # enable labelled bounding boxes on the live + recorded feed
# DETECT_EVERY=6           # run inference every Nth frame (higher = lighter CPU)
# DETECT_CONF=0.5          # min confidence (0-1) to draw a box
# DETECT_ALERT=person      # classes that raise an event + trigger recording (comma list)
# DETECT_CLASSES=          # restrict drawn classes (comma list); empty = all 20 VOC classes
# DETECT_MODEL_DIR=/opt/vigil/models   # holds MobileNetSSD_deploy.prototxt + .caffemodel
