# Sinsera kiosk X session (openbox). The cursor is hidden by unclutter — which is the
# whole point of moving off cage+cog (cog draws a cursor nothing can hide on touch).
xset s off &
xset -dpms &
xset s noblank &
xrandr --auto &
unclutter -idle 0.1 -root &
[ -f /opt/sinsera-node/display.env ] && . /opt/sinsera-node/display.env
DSF="${KIOSK_SCALE:-1.0}"
# Clear chromium's HTTP/GPU cache ONCE per session (not per relaunch) so a stale cache
# after a reboot can't leave the wall on a white screen. Login/session live elsewhere.
rm -rf /home/kiosk/.config/chromium/Default/Cache/* \
       "/home/kiosk/.config/chromium/Default/Code Cache/"* \
       /home/kiosk/.config/chromium/Default/GPUCache/* 2>/dev/null
while true; do
  rm -f /home/kiosk/.config/chromium/Singleton* 2>/dev/null
  # Re-mint the auth hash if the boot-time token has gone stale (session-reuse
  # via refresh grant — a relaunch hours after boot must not wake signed out).
  /usr/local/bin/sinsera-kiosk-freshurl.sh 2>/dev/null || true
  URL=$(cat /tmp/kiosk_url 2>/dev/null); [ -n "$URL" ] || URL="https://sinsera.co/?kiosk=1"
  chromium \
    --kiosk --noerrdialogs --disable-infobars --no-first-run --start-maximized \
    --disable-session-crashed-bubble --disable-features=Translate \
    --check-for-update-interval=31536000 --ozone-platform=x11 \
    --force-device-scale-factor="$DSF" \
    --user-data-dir=/home/kiosk/.config/chromium \
    "$URL" >>/var/log/sinsera-kiosk.log 2>&1
  sleep 3
done &
