# garage-pi-bridge .env — Node 5 (GR86). Baked by install.sh at bake time; the
# public anon key + owner email + owner id are filled in automatically, and the
# PLACEHOLDERS below are left for you to complete over SSH before first drive:
#   ssh peta@node5.local 'sudo nano /opt/garage-pi-bridge/.env && sudo systemctl restart garage-obd-bridge'

# Supabase (public anon key — baked from Sinsera Core .env.production)
SUPABASE_URL=https://lkhtgkmivqwgnvzmjbhr.supabase.co
SUPABASE_ANON_KEY=

# Auth — bridge signs in to inherit the owner's RLS. Password stays BLANK in the
# baked image (like Vigil): fill over SSH to turn on the cloud push.
SUPABASE_EMAIL=peta.stockdale@outlook.com
SUPABASE_PASSWORD=

# Owner id (RLS): 82e75fd1-7878-45f5-9760-ba0af6838a3d  (informational; the bridge
# derives user_id from the signed-in session, but this documents the owner).
OWNER_ID=82e75fd1-7878-45f5-9760-ba0af6838a3d

# PLACEHOLDER — the UUID of the GR86 row in garage_cars:
#   select id from garage_cars where user_id = auth.uid() and nickname ilike '%gr86%';
CAR_ID=

# PLACEHOLDER — OBDLink MX+ Bluetooth MAC (pair once via `sudo bluetoothctl`,
# then paste it here). The Ugreen BT 6.0 USB dongle is the radio it talks over.
OBDLINK_MAC=
OBDLINK_NAME=OBDLink MX+

# Sampling
SAMPLE_HZ=5
DTC_POLL_SECS=10
BATCH_SIZE=10
